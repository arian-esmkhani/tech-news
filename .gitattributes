# ==========================================
# BACKEND: Fiber
# ==========================================

# Go
*.go linguist-language=Go
go.mod linguist-language=TypeScript
go.sum linguist-language=Go

# ==========================================
# FRONTEND: Next.js (Main App)
# ==========================================

# TypeScript/JavaScript
frontend/main/**/*.ts linguist-detectable=false
frontend/main/**/*.tsx linguist-detectable=false
frontend/main/**/*.js linguist-language=JavaScript
frontend/main/**/*.jsx linguist-language=TypeScript
frontend/main/**/*.css linguist-language=CSS
frontend/main/**/*.scss linguist-language=SCSS


# ==========================================
# DOCKER & INFRASTRUCTURE
# ==========================================

# Docker
Dockerfile linguist-language=Dockerfile
**/Dockerfile linguist-language=Dockerfile
*.dockerfile linguist-language=Dockerfile

# Docker Compose
docker-compose.yml linguist-language=YAML
docker-compose*.yml linguist-language=YAML
*.yml linguist-language=YAML
*.md linguist-language=Markdown

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf